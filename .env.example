# ── OpenAI (이미지 분석용) — 이거 하나만 채우면 됩니다 ──────────────────
# https://platform.openai.com/api-keys 에서 발급 (결제 정보 등록 필요, 종량제)
OPENAI_API_KEY="여기에_OpenAI_API_키"
# 필요 시에만 교체하세요 (기본값 권장 — 비전 지원 + 저렴)
OPENAI_MODEL="gpt-4o-mini"

# 프로덕션 배포 시 true로 설정
NODE_ENV="development"


# ── (정확도 ↑) 네이버 쇼핑 API — 무료, 후보 상품 풀을 크게 넓혀줍니다 ────
# https://developers.naver.com 에서 앱 등록 후 발급 (검색 API 사용 설정)
# 없으면 네이버 결과 대신 네이버쇼핑 검색 링크로 폴백합니다.
# NAVER_CLIENT_ID="네이버_클라이언트_ID"
# NAVER_CLIENT_SECRET="네이버_클라이언트_시크릿"

# ── (정확도 ↑↑) 구글 렌즈 시각 검색 (SerpApi) — 사진과 똑같은 상품 찾기 ──
# https://serpapi.com/manage-api-key 에서 발급 (무료 월 100회, 이후 유료)
# 없으면 "사진과 똑같은 상품" 섹션이 그냥 표시되지 않습니다 (앱은 정상 동작).
# SERPAPI_KEY="SerpApi_키"


# ══════════════════════════════════════════════════════════════════════
# 아래는 전부 선택 사항입니다. 안 채워도 앱은 정상 작동해요.
# Pinterest 연동은 개발자 앱 없이 "아이디 입력 → 공개 RSS" 방식으로 동작합니다.
# ══════════════════════════════════════════════════════════════════════

# ── (선택) Pinterest OAuth — 공식 개발자 앱 승인을 받은 경우에만 ────────
# 2026년 기준 Pinterest 트라이얼 승인이 대부분 거부되어 사실상 쓰기 어렵습니다.
# 승인을 받았다면 아래 값을 채우고 server/pinterestClient.ts 경로를 활성화하세요.
# PINTEREST_CLIENT_ID="핀터레스트_앱_ID"
# PINTEREST_CLIENT_SECRET="핀터레스트_앱_시크릿"
# PINTEREST_REDIRECT_URI="http://localhost:3002/api/auth/pinterest/callback"

# (선택) OAuth 사용 시 쿠키 서명용 임의의 긴 문자열
SESSION_SECRET="바꿔주세요_아무_랜덤_문자열_32자_이상"
